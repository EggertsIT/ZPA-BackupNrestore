ZSCALER_CLIENT_ID=your-client-id
ZSCALER_CLIENT_SECRET=your-client-secret
ZSCALER_CUSTOMER_ID=your-customer-id
ZSCALER_AUTH_MODE=legacy
ZSCALER_ZPA_BASE_URL=https://config.private.zscaler.com
# Required only when ZSCALER_AUTH_MODE=oneapi.
# ZSCALER_ZIDENTITY_BASE_URL=https://your-zidentity-domain.example
# ZSCALER_ONEAPI_BASE_URL=https://api.zsapi.net
# Optional, use 0 for the default microtenant when needed.
# ZSCALER_MICROTENANT_ID=0

# ZPA-Backup and Restore source tenant.
ZPA_SOURCE_AUTH_MODE=legacy
ZPA_SOURCE_CLIENT_ID=source-client-id
ZPA_SOURCE_CLIENT_SECRET=source-client-secret
ZPA_SOURCE_CUSTOMER_ID=source-customer-id
ZPA_SOURCE_ZPA_BASE_URL=https://config.private.zscaler.com
# ZPA_SOURCE_ZIDENTITY_BASE_URL=https://source-zidentity-domain.example
# ZPA_SOURCE_ONEAPI_BASE_URL=https://api.zsapi.net
# ZPA_SOURCE_MICROTENANT_ID=0

# ZPA-Backup and Restore destination tenant.
ZPA_TARGET_AUTH_MODE=legacy
ZPA_TARGET_CLIENT_ID=target-client-id
ZPA_TARGET_CLIENT_SECRET=target-client-secret
ZPA_TARGET_CUSTOMER_ID=target-customer-id
ZPA_TARGET_ZPA_BASE_URL=https://config.private.zscaler.com
# ZPA_TARGET_ZIDENTITY_BASE_URL=https://target-zidentity-domain.example
# ZPA_TARGET_ONEAPI_BASE_URL=https://api.zsapi.net
# ZPA_TARGET_MICROTENANT_ID=0
